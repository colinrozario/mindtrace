# Ignore web-related files to highlight Python in GitHub language stats without completely removing Javascript
public/** linguist-vendored
dist/** linguist-vendored
build/** linguist-vendored
client/build/** linguist-vendored
client/dist/** linguist-vendored
*.html linguist-vendored
*.css linguist-vendored
*.svg linguist-vendored
package-lock.json linguist-generated=true
yarn.lock linguist-generated=true
pnpm-lock.yaml linguist-generated=true

# Force backend text or config files (if any) to Python (optional, depending on volume)
